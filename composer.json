{
    "name": "chuckbartowski/ovh-sdk",
    "description": "PHP SDK for the OVHcloud API — native request signing, typed clients and high-level modules for every product",
    "type": "library",
    "license": "MIT",
    "keywords": ["ovh", "ovhcloud", "api", "sdk", "cloud", "hosting", "domain", "php"],
    "authors": [
        {
            "name": "Chuck Bartowski"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/http-client-contracts": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "symfony/config": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/http-kernel": "^6.4|^7.0"
    },
    "suggest": {
        "symfony/http-kernel": "To register OvhSdkBundle in a Symfony application",
        "symfony/config": "To register OvhSdkBundle in a Symfony application",
        "symfony/dependency-injection": "To register OvhSdkBundle in a Symfony application"
    },
    "autoload": {
        "psr-4": {
            "ChuckBartowski\\OvhSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChuckBartowski\\OvhSdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
